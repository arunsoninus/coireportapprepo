{
  "_version": "1.82.0",
  "sap.app": {
    "id": "nus.edu.sg.coireport",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.3",
      "toolsId": "8417d945-4561-48c5-a8d9-d94a32ddbbdc"
    },
     "dataSources": {
      "utilService": {
        "uri": "/v2/util",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/util_metadata.xml",
          "odataVersion": "2.0"
        }
      },
      "catalogService": {
        "uri": "/v2/catalog/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/catalog.xml",
          "odataVersion": "2.0"
        }
      },
      "coiReportService": {
        "uri": "/odata/v2/cwned/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/catalog.xml",
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "coireport-display": {
          "semanticObject": "coireport",
          "action": "display",
          "title": "{{coireport-display.flpTitle}}",
          "subTitle": "{{coireport-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "nus.edu.sg.coireport.i18n.i18n"
        }
      },
      "CatalogSrvModel": {
        "dataSource": "catalogService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "UtilitySrvModel": {
        "dataSource": "utilService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "CoiReportSrvModel": {
        "dataSource": "coiReportService",
        "preload": true,
        "settings": {
          "useBatch": false,
          "operationMode": "Server",
          "autoExpandSelect": true,
          "synchronizationMode": "None",
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "nus.edu.sg.coireport.view",
        "async": true,
        "viewPath": "nus.edu.sg.coireport.view"
      },
      "routes": [
        {
          "name": "RouteCoiHome",
          "pattern": "RouteCoiHome",
          "target": [
            "TargetCoiHome"
          ]
        }
      ],
      "targets": {
        "TargetCoiHome": {
          "id": "CoiHome",
          "name": "CoiHome"
        }
      }
    },
    "rootView": {
      "viewName": "nus.edu.sg.coireport.view.CoiHome",
      "type": "XML",
      "id": "CoiHome",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "coireportapp"
  }
}